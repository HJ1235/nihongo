SPRING_PROFILES_ACTIVE=dev
PORT=8080
DB_URL=jdbc:postgresql://localhost:5432/nihongo
DB_USERNAME=nihongo
DB_PASSWORD=<local-db-password>
JWT_SECRET=<your-local-jwt-secret-at-least-32-characters>
CORS_ALLOWED_ORIGINS=http://localhost:5173

# AI correction provider: mock, openai, or gemini
AI_CORRECTION_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_CORRECTION_MODEL=gpt-5.2
GEMINI_API_KEY=
GEMINI_CORRECTION_MODEL=gemini-2.5-flash

# Production custom-domain CORS example
# CORS_ALLOWED_ORIGINS=https://nihongotest.shop,https://www.nihongotest.shop,https://nihongo-plum-chi.vercel.app
